{
  "name": "repo-butler",
  "version": "0.1.0",
  "description": "Continuous roadmap planner agent — analyses GitHub repos, maintains a living roadmap, and proposes improvements",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node --env-file=.env.local src/index.js",
    "observe": "node --env-file=.env.local src/index.js --phase=observe",
    "report": "node --env-file=.env.local src/index.js --phase=report",
    "assess": "node --env-file=.env.local src/index.js --phase=assess",
    "all": "node --env-file=.env.local src/index.js --phase=all",
    "test": "find src -name '*.test.js' -print0 | xargs -0 node --test"
  },
  "keywords": [
    "github",
    "roadmap",
    "agent",
    "automation"
  ],
  "author": "IsmaelMartinez",
  "license": "MIT"
}
